generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Escola {
  id       Int          @id @default(autoincrement())
  nome     String
  endereco String?
  telefone String?
  adis     ADI[]
  avisos   AvisoGeral[]
  turmas   Turma[]
}

model Turma {
  id        Int             @id @default(autoincrement())
  nome      String
  anoLetivo Int
  escolaId  Int
  bebes     Bebe[]
  escola    Escola          @relation(fields: [escolaId], references: [id])
  vivencias VivenciaGeral[]
  adis      ADI[]           @relation("ADITurma")
}

model Bebe {
  id               Int                @id @default(autoincrement())
  nome             String
  dataNascimento   DateTime?
  genero           String?
  alergias         String?
  medicamentos     String?
  observacoesSaude String?
  autorizadosBusca String?
  fotoUrl          String?
  turmaId          Int
  turma            Turma              @relation(fields: [turmaId], references: [id])
  diarios          DiarioIndividual[]
  ocorrencias      Ocorrencia[]
  responsaveis     Responsavel[]      @relation("BebeResponsavel")
}

model Responsavel {
  id        Int     @id @default(autoincrement())
  nome      String
  cpf       String  @unique
  telefone  String?
  email     String  @unique
  senhaHash String
  endereco  String?
  bebes     Bebe[]  @relation("BebeResponsavel")
}

model ADI {
  id          Int                @id @default(autoincrement())
  nome        String
  matricula   String             @unique
  email       String             @unique
  senhaHash   String
  escolaId    Int
  escola      Escola             @relation(fields: [escolaId], references: [id])
  diarios     DiarioIndividual[]
  ocorrencias Ocorrencia[]
  vivencias   VivenciaGeral[]
  turmas      Turma[]            @relation("ADITurma")
}

model DiarioIndividual {
  id                        Int       @id @default(autoincrement())
  data                      DateTime  @default(now())
  frequencia                Boolean   @default(true)
  chegadaHumor              String?
  alimentacao               String?
  banho                     Boolean   @default(false)
  sono                      String?
  desenvolvimentoPedagogico String?
  enviadoEm                 DateTime?
  bebeId                    Int
  adiId                     Int
  adi                       ADI       @relation(fields: [adiId], references: [id])
  bebe                      Bebe      @relation(fields: [bebeId], references: [id])
}

model Ocorrencia {
  id         Int      @id @default(autoincrement())
  titulo     String
  descricao  String
  horario    DateTime @default(now())
  prioridade String   @default("BAIXA")
  bebeId     Int
  adiId      Int
  adi        ADI      @relation(fields: [adiId], references: [id])
  bebe       Bebe     @relation(fields: [bebeId], references: [id])
}

model VivenciaGeral {
  id        Int      @id @default(autoincrement())
  data      DateTime @default(now())
  titulo    String
  descricao String
  fotosJson Json?
  turmaId   Int
  adiId     Int
  adi       ADI      @relation(fields: [adiId], references: [id])
  turma     Turma    @relation(fields: [turmaId], references: [id])
}

model AvisoGeral {
  id            Int       @id @default(autoincrement())
  titulo        String
  conteudo      String
  dataCriacao   DateTime  @default(now())
  dataExpiracao DateTime?
  escolaId      Int
  escola        Escola    @relation(fields: [escolaId], references: [id])
}
